{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistencia": {
    "Modo": "Memoria"
  },
  "Seguranca": {
    "JwtIssuer": "Reorbita.Api",
    "JwtAudience": "Reorbita.Operadoras",
    "JwtExpiracaoMinutos": 120,
    "ExigirMtlsCanalRobos": false
  },
  "RateLimiting": {
    "TelemetriaPermitLimit": 30,
    "TelemetriaJanelaSegundos": 60
  },
  "AllowedHosts": "*"
}
